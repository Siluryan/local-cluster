kubeconfig_path = "~/.kube/config"
kube_context      = "kind-kind"

cluster_domain = "example.local"
acme_email     = "ops@example.com"

bind_zone           = "example.local"
bind_tsig_key_name  = "externaldns-key"
bind_tsig_secret    = "changeme"
bind_tsig_algorithm = "hmac-sha256"

grafana_admin_password  = "changeme"
cloudflare_tunnel_token = "changeme"

vaultwarden_admin_token = "changeme"

postfix_enabled                      = false
postfix_extra_allowed_sender_domains = ""
postfix_relayhost                    = ""
postfix_relay_username               = ""
postfix_relay_password               = ""

vaultwarden_smtp_host      = "smtp.gmail.com"
vaultwarden_smtp_port      = "587"
vaultwarden_smtp_security  = "starttls"
vaultwarden_smtp_username  = "user@example.com"
vaultwarden_smtp_password  = "changeme"
vaultwarden_smtp_from      = "user@example.com"
vaultwarden_smtp_from_name = "Vaultwarden"
vaultwarden_smtp_accept_invalid_certs    = false
vaultwarden_config_patch_invalid_certs   = true
vaultwarden_config_patch_run_id          = "1"

wireguard_admin_password_hash = "$2y$12$changeme"
wireguard_public_host         = ""

nexus_admin_password       = "changeme"
keycloak_admin_password    = "changeme"
keycloak_postgres_password = "changeme"
keycloak_chart_archive_path = null
enable_wazuh                  = true

registry_htpasswd = "user:$2y$12$changeme"

headlamp_oauth_client_id      = "headlamp"
headlamp_oauth_client_secret  = "changeme-keycloak-client-secret"
headlamp_oauth_keycloak_realm = "master"
